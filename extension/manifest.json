{
  "manifest_version": 3,
  "name": "SatyaCheck — Proactive Media Integrity Guard",
  "version": "1.0.0",
  "description": "Authenticates corporate disclosures and filters synthetic media/scams in-feed.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
